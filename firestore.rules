rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can read all, write own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Entries collection - read all, create/update own only
    match /entries/{entryId} {
      // Anyone authenticated can read entries (org-level visibility)
      allow read: if request.auth != null;
      
      // Only create entries with user's own ID
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      
      // Can only update/delete own entries
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}